-UINT32 DebugCategory = DBG_CAT_EN_ALL_MASK
+UINT32 DebugCategory = 0;
+
+/* Initialize debug settings based on enable_debug parameter */
+void __init init_debug_settings(void)
+{
+	if (enable_debug) {
+		DebugLevel = DBG_LVL_NOTICE;
+		DebugCategory = DBG_CAT_EN_ALL_MASK
 				& ~(0x1 << DBG_CAT_TX)
 				& ~(0x1 << DBG_CAT_PS);
+	} else {
+		DebugLevel = DBG_LVL_OFF;
+		DebugCategory = 0;
+	}
+}
 
